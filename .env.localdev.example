# Copy this file to .env.localdev for one-command local development.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...
TAVILY_API_KEY=tvly-...

DB_DSN=postgresql://postgres:postgres@localhost:55432/persistent_agent_runtime
VITE_API_BASE_URL=http://localhost:8080
APP_DEV_TASK_CONTROLS_ENABLED=false
LEASE_DURATION_SECONDS=60
HEARTBEAT_INTERVAL_SECONDS=15
REAPER_INTERVAL_SECONDS=30
REAPER_JITTER_SECONDS=10

# Langfuse is now configured per-agent via the Console Settings page.
# To run a local Langfuse instance for testing: make dev-langfuse-up
# Then register it as an endpoint in the Console Settings page.
