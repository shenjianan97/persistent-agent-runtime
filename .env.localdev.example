# Copy this file to .env.localdev for one-command local development.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...
TAVILY_API_KEY=tvly-...

DB_DSN=postgresql://postgres:postgres@localhost:55432/persistent_agent_runtime
VITE_API_BASE_URL=http://localhost:8080
APP_DEV_TASK_CONTROLS_ENABLED=false
LANGFUSE_ENABLED=true
LANGFUSE_HOST=http://127.0.0.1:3300
LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_SECRET_KEY=sk-lf-local
LANGFUSE_INIT_ORG_ID=persistent-agent-runtime-local
LANGFUSE_INIT_PROJECT_ID=persistent-agent-runtime-local
LANGFUSE_INIT_USER_EMAIL=local@example.com
LANGFUSE_INIT_USER_PASSWORD=LocalDevPass123!
LEASE_DURATION_SECONDS=60
HEARTBEAT_INTERVAL_SECONDS=15
REAPER_INTERVAL_SECONDS=30
REAPER_JITTER_SECONDS=10
